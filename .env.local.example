# Claw Learn Environment Variables
# Copy this file to .env.local and fill in your keys

# ── AI Provider (OpenAI-compatible) ──────────────────────────────────────────
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
OPENAI_MODEL=gemini-2.5-flash

# ── Auth (NextAuth) ───────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
AUTH_SECRET=your_auth_secret_here

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# GitHub OAuth — https://github.com/settings/developers
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret

# ── Rate limiting (Upstash Redis) ─────────────────────────────────────────────
# Create a free Redis DB at https://console.upstash.com/
# Without these, rate limiting falls back to in-memory (resets on server restart)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ── ElevenLabs Voice (optional) ───────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
ELEVENLABS_SPEECH_ENGINE_ID=your_speech_engine_id_here

# ── Security ──────────────────────────────────────────────────────────────────
ALLOWED_ORIGIN=https://your-domain.com
