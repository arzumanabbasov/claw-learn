# Claw Learn Environment Variables
# Copy this file to .env.local and fill in your API keys
# Alternatively, configure keys directly in the app's Settings page (⚙ icon in the top bar).

# ── AI Provider (OpenAI-compatible) ──────────────────────────────────────────
# Works with Gemini, OpenAI, Ollama, or any OpenAI-compatible provider.

# API key for your chosen provider (required)
OPENAI_API_KEY=your_api_key_here

# Base URL of the OpenAI-compatible endpoint
# Gemini:  https://generativelanguage.googleapis.com/v1beta/openai
# OpenAI:  https://api.openai.com/v1
# Ollama:  http://localhost:11434/v1
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Model name to use
# Gemini:  gemini-2.5-flash
# OpenAI:  gpt-4o
# Ollama:  llama3.1
OPENAI_MODEL=gemini-2.5-flash

# Legacy: still supported if OPENAI_API_KEY is not set
# GEMINI_API_KEY=your_gemini_api_key_here

# ── ElevenLabs Voice (optional) ───────────────────────────────────────────────
# App works without narration if these are not set.

# ElevenLabs API Key — get yours at https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Voice ID — default is Adam
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# Speech Engine ID (optional - enables WebRTC voice I/O)
# Create a Speech Engine at: https://elevenlabs.io/app/conversational-ai
ELEVENLABS_SPEECH_ENGINE_ID=your_speech_engine_id_here

# ── Security ──────────────────────────────────────────────────────────────────
# Lock CORS to your domain in production (recommended on Vercel)
# ALLOWED_ORIGIN=https://your-domain.com
